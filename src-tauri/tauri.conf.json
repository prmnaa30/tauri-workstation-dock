{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nook",
  "version": "1.1.0",
  "identifier": "com.nook",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nook",
        "width": 1280,
        "height": 760,
        "visible": false,
        "center": true,
        "dragDropEnabled": false
      },
      {
        "label": "floating",
        "title": "Nook Bar",
        "width": 650,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
